{
  "rules": {
    ".read": "auth != null",
    ".write": "auth != null",

    "authRollBindings": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid && (!data.exists() || data.val() === newData.val())",
        ".validate": "newData.isString() && newData.val().matches(/^[0-9]{7}$/)"
      }
    },

    "codeSnippetComments": {
      "$snippetId": {
        ".indexOn": ["timestamp", "author/roll"],
        ".read": "auth != null",
        "$commentId": {
          ".write": "auth != null",
          ".validate": "newData.hasChildren(['content', 'author', 'timestamp'])"
        }
      }
    },

    "doubts": {
      ".indexOn": ["status", "timestamp", "userDetails/roll"],
      "$doubtId": {
        ".read": "auth != null",
        ".write": "auth != null",
        ".validate": "newData.hasChildren(['title', 'description', 'userDetails', 'timestamp'])"
      }
    },

    "resolvedDoubts": {
      ".indexOn": ["userSatisfied", "timestamp", "status"],
      "$doubtId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },

    "notifications": {
      "$userRoll": {
        ".indexOn": ["read", "timestamp", "type"],
        ".read": "auth != null && root.child('authRollBindings').child(auth.uid).val() === $userRoll",
        ".write": "auth != null && root.child('authRollBindings').child(auth.uid).val() === $userRoll",
        "$notificationId": {
          ".validate": true
        }
      }
    },

    "userNutrinos": {
      "$userRoll": {
        ".indexOn": ["totalNutrinos", "lastUpdated"],
        ".read": "auth != null && root.child('authRollBindings').child(auth.uid).val() === $userRoll",
        ".write": "auth != null && root.child('authRollBindings').child(auth.uid).val() === $userRoll"
      }
    },

    "solverPoints": {
      "$userRoll": {
        ".indexOn": ["totalPoints", "doubtsResolved"],
        ".read": "auth != null && root.child('authRollBindings').child(auth.uid).val() === $userRoll",
        ".write": "auth != null && root.child('authRollBindings').child(auth.uid).val() === $userRoll"
      }
    },

    "reviewerNotifications": {
      ".indexOn": ["timestamp", "read", "type"],
      "$notificationId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },

    "groupMessages": {
      "$groupId": {
        ".indexOn": ["timestamp", "senderRoll"],
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },

    "groupPolls": {
      "$groupId": {
        ".indexOn": ["timestamp", "isActive", "createdBy"],
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },

    "presence": {
      "$userRoll": {
        ".read": "auth != null && root.child('authRollBindings').child(auth.uid).val() === $userRoll",
        ".write": "auth != null && root.child('authRollBindings').child(auth.uid).val() === $userRoll",
        ".validate": "newData.hasChildren(['online', 'lastSeen'])"
      }
    },

    "activeUsers": {
      "$userRoll": {
        ".read": "auth != null && root.child('authRollBindings').child(auth.uid).val() === $userRoll",
        ".write": "auth != null && root.child('authRollBindings').child(auth.uid).val() === $userRoll"
      }
    },

    "typingIndicators": {
      "$groupId": {
        "$userRoll": {
          ".read": "auth != null && root.child('authRollBindings').child(auth.uid).val() === $userRoll",
          ".write": "auth != null && root.child('authRollBindings').child(auth.uid).val() === $userRoll"
        }
      }
    }
  }
}
